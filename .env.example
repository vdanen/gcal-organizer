# GCal Organizer Environment Variables

# Required: GCP API Key for Gemini AI
GEMINI_API_KEY=your-gcp-api-key-here

# Required: Path to Google OAuth2 credentials JSON file
GOOGLE_CREDENTIALS_FILE=~/.gcal-organizer/credentials.json

# Optional: Master folder name in Google Drive (default: "Meeting Notes")
GCAL_MASTER_FOLDER_NAME=Meeting Notes

# Optional: Days to look back for calendar events (default: 1)
GCAL_DAYS_TO_LOOK_BACK=1

# Optional: Keywords to filter documents (comma-separated)
GCAL_FILENAME_KEYWORDS=Notes,Meeting

# Optional: Regex pattern for parsing document names
# Default matches "Meeting Name - YYYY-MM-DD" format
GCAL_FILENAME_PATTERN=(.+)\s*-\s*(\d{4}-\d{2}-\d{2})

# Optional: Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: Disable OS credential store; use file-based storage (default: false)
# GCAL_NO_KEYRING=false
